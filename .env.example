# KIS Open API 엔드포인트 (기본값 그대로 사용 가능, 변경 필요 시 설정)
KIS_REST_URL_LIVE=https://openapi.koreainvestment.com:9443
KIS_REST_URL_PAPER=https://openapivts.koreainvestment.com:29443
KIS_REST_URL_MOCK=http://localhost:8000

KIS_WS_BASE_LIVE=ws://ops.koreainvestment.com:21000
KIS_WS_BASE_PAPER=ws://ops.koreainvestment.com:31000
KIS_WS_PATH=/tryitout/H0STCNT0
KIS_WS_URL_MOCK=ws://localhost:8000/ws

# Rate limit (초 단위, 기본 0.06 = 초당 최대 16건)
KIS_RATE_LIMIT_SEC=0.06

# AI provider keys (config.yaml의 ai.provider에 맞는 값만 필수)
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# PostgreSQL DSN fallback (db/pg_writer.py에서 사용)
DATABASE_URL=postgresql://localhost:5432/quant_trading
