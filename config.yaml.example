mode: paper   # paper | live | mock

database:
  host: "localhost"
  port: 5432
  name: "quant_trading"
  user: ""                  # 비우면 현재 OS 사용자 사용
  password: ""              # 비밀번호 없으면 빈 문자열

redis:
  host: "localhost"
  port: 6379
  db: 0

ai:
  provider: "gemini"        # gemini | groq | anthropic
  morning_brief_hour: 8
  morning_brief_minute: 30

kis:
  paper_app_key: ""          # KIS Developers 모의투자 앱키
  paper_app_secret: ""       # KIS Developers 모의투자 앱시크릿
  live_app_key: ""           # KIS Developers 실전투자 앱키
  live_app_secret: ""        # KIS Developers 실전투자 앱시크릿
  paper_account_no: ""       # 모의투자 계좌번호 (8자리)
  paper_account_product_code: "01"
  live_account_no: ""        # 실전투자 계좌번호 (8자리)
  live_account_product_code: "01"
  hts_id: ""                 # KIS HTS 이용자 ID (체결통보 WebSocket tr_key)
  domestic_market: "UN"      # UN=통합(KRX+NXT), J=KRX

trading:
  stop_loss_pct: 5.0
  take_profit_pct: 5.0
  max_positions: 5
  position_size_pct: 10.0

universe:
  domestic:
    markets: ["J"]
    top_n: 100
    stocks: []               # fallback 종목 리스트 (거래량 순위 API 실패 시)
  overseas:
    exchanges: ["NAS", "NYS"]
    top_n: 50
    stocks: []

backtest:
  candle_minutes: 15
  lookback_days: 30
  daytrade_lookback_days: 10

schedule:
  auto: false
  allow_live_auto_trading: false # live 자동매매를 명시적으로 허용할 때만 true
  analysis_offset_min: 30
  rerank_offset_min: 10
  domestic_analysis_time: "09:00"
  domestic_trading_end_time: "15:20"
  us_daytime_start: "10:00"
  us_daytime_end: "16:00"
  us_analysis_time: "22:30"
  us_trading_end_time: "05:00"
  report_time: "16:00"
  confirmation_timeout_sec: 60

logging:
  level: "INFO"
  file: "data/trading.log"
